NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME="Bolder Vibes API"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=3801
POSTGRES_DB=bolder_vibes_db
DATABASE_URL="postgresql://postgres:3801@localhost:5432/bolder_vibes_db"
SKIP_DB_CONNECT=false

CORS_ORIGIN=*
JWT_SECRET="change-me-super-secret"
JWT_EXPIRES_IN=7d
AUTH_BCRYPT_ROUNDS=12

REDIS_URL="redis://localhost:6379"
AI_QUEUE_NAME=ai-prompt-runs
AI_QUEUE_PROCESS_INLINE=true
AI_AUTO_START_RUNTIME=true
AI_PROVIDER_DEFAULT=mock
AI_REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1"
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_MODEL="claude-3-7-sonnet-20250219"

PREVIEW_BASE_URL="http://preview.local"
PROJECTS_ROOT="/var/lib/bolder-vibes/generated-projects"
DOCKER_BINARY=docker
DOCKER_SANDBOX_NETWORK=bridge
RUNTIME_CPU_LIMIT=1
RUNTIME_MEMORY_MB=512
RUNTIME_INTERNAL_PORT=3000
EXECUTE_DOCKER=false

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
