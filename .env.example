NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME="Bolder Vibes API"
DATABASE_URL="postgresql://postgres:password@localhost:5432/bolder_vibes_db"
SKIP_DB_CONNECT=false
CORS_ORIGIN=*
PREVIEW_BASE_URL="http://preview.local"
PROJECTS_ROOT="/var/lib/bolder-vibes/generated-projects"
DOCKER_SANDBOX_NETWORK=bridge
RUNTIME_CPU_LIMIT=1
RUNTIME_MEMORY_MB=512
EXECUTE_DOCKER=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120